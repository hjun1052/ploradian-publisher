---
import type { Article } from "../lib/articles";
import { formatDisplayDate } from "../lib/articles";

interface Props {
  article: Article;
  variant?: "lead" | "standard" | "brief";
}

const { article, variant = "standard" } = Astro.props;
const href = `/article/${article.slug}/`;
const unsplashCreditUrl = "https://unsplash.com/?utm_source=the_ploradian&utm_medium=referral";
---

<article class:list={["article-card", `article-card-${variant}`]}>
  {variant !== "brief" && article.image_url && (
    <figure class="article-card-media">
      <a class="article-card-image" href={href} aria-label={article.title}>
        <img
          src={article.image_url}
          alt={article.image_alt || ""}
          loading={variant === "lead" ? "eager" : "lazy"}
          decoding="async"
        />
      </a>
      {article.image_credit_name && article.image_credit_url && (
        <figcaption>
          Photo by
          {" "}
          <a href={article.image_credit_url} rel="noopener noreferrer" target="_blank">
            {article.image_credit_name}
          </a>
          {" "}
          on
          {" "}
          <a href={unsplashCreditUrl} rel="noopener noreferrer" target="_blank">Unsplash</a>
        </figcaption>
      )}
    </figure>
  )}
  <p class="kicker">{article.category}</p>
  <h2>
    <a href={href}>{article.title}</a>
  </h2>
  {variant !== "brief" && <p class="deck">{article.subtitle}</p>}
  {variant === "lead" && <p class="excerpt">{article.excerpt}</p>}
  <p class="article-meta">
    <time datetime={article.date}>{formatDisplayDate(article.date)}</time>
    <span aria-hidden="true">/</span>
    <span>{article.source_name}</span>
  </p>
</article>
