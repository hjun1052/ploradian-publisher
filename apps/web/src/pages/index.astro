---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { formatDisplayDate, getPublishedArticles } from "../lib/articles";
import { getHomeFeaturedArticles } from "../lib/homeRanking";

const articles = await getPublishedArticles();
const featuredArticles = getHomeFeaturedArticles(articles, 9);
const featuredSlugs = new Set(featuredArticles.map((article) => article.slug));
const lead = featuredArticles[0];
const secondary = featuredArticles.slice(1, 3);
const briefs = featuredArticles.slice(3, 9);
const latestRows = articles.filter((article) => !featuredSlugs.has(article.slug)).slice(0, 16);
const sectionOrder = ["기술", "비즈니스", "시장", "정색", "헛소리"];
const sections = sectionOrder
  .map((category) => ({
    category,
    articles: articles.filter((article) => article.category === category).slice(0, 4)
  }))
  .filter((section) => section.articles.length > 0);
---

<BaseLayout
  title="The Ploradian"
  description="The Ploradian은 기술, 비즈니스, 시장, 헛소리 뉴스를 한국어 풍자 기사로 자동 발행하는 온라인 신문입니다."
  canonicalPath="/"
>
  <section class="site-shell front-page" aria-labelledby="front-page-title">
    <div class="section-rule">
      <p class="section-label">Latest Edition</p>
      <h1 id="front-page-title">Technology, business, markets, and stray nonsense explained with a straight face.</h1>
    </div>

    {lead ? (
      <>
        <div class="front-page-grid">
          <div class="lead-column">
            <ArticleCard article={lead} variant="lead" />
          </div>
          <div class="secondary-column" aria-label="Secondary stories">
            {secondary.length > 0 ? (
              secondary.map((article) => <ArticleCard article={article} variant="standard" />)
            ) : (
              <p class="empty-note">자동 발행이 새 기사를 준비하는 중입니다.</p>
            )}
          </div>
          <aside class="briefs-column" aria-label="Latest briefs">
            <h2 class="column-heading">Briefs</h2>
            {briefs.length > 0 ? (
              briefs.map((article) => <ArticleCard article={article} variant="brief" />)
            ) : (
              <p class="empty-note">다음 발행분이 도착하면 이 영역에 짧은 기사 목록이 표시됩니다.</p>
            )}
          </aside>
        </div>

        {(latestRows.length > 0 || sections.length > 0) && (
          <div class="front-page-afterfold">
            {latestRows.length > 0 && (
              <section class="home-latest" aria-labelledby="home-latest-title">
                <div class="home-section-heading">
                  <p class="section-label">Latest Stories</p>
                  <h2 id="home-latest-title">More from the current desk</h2>
                </div>
                <ol class="home-latest-list">
                  {latestRows.map((article) => (
                    <li class="home-latest-row">
                      <a href={`/article/${article.slug}/`}>
                        <span class="home-row-category">{article.category}</span>
                        <span class="home-row-title">{article.title}</span>
                        <span class="home-row-meta">{formatDisplayDate(article.date)}</span>
                      </a>
                    </li>
                  ))}
                </ol>
              </section>
            )}

            <section class="home-weather" aria-labelledby="home-weather-title">
              <div class="home-section-heading">
                <p class="section-label">Weather</p>
                <h2 id="home-weather-title">오늘의 일기예보</h2>
              </div>
              <div class="home-weather-body">
                <p>오늘은 -40도에서 40도 사이 온도가 지속되겠습니다.</p>
                <p>하늘은 오늘 푸른색일 예정입니다.</p>
                <p>바람은 불겠으며, 우산은 비막이, 양산, 장식품 중 하나의 용도로 사용되겠습니다.</p>
                <p>대기에는 먼지가 날아다니겠으며, 오전 4시부터 8시 사이에 해가 뜨고, 오후 4시부터 8시 사이에 해가 지겠습니다.</p>
              </div>
            </section>

            {sections.length > 0 && (
              <section class="home-sections" aria-labelledby="home-sections-title">
                <div class="home-section-heading home-section-heading-wide">
                  <p class="section-label">By Section</p>
                  <h2 id="home-sections-title">Filed under the usual suspicions</h2>
                </div>
                <div class="home-section-grid">
                  {sections.map((section) => (
                    <section class="home-category-block" aria-labelledby={`home-category-${section.category}`}>
                      <h3 id={`home-category-${section.category}`}>{section.category}</h3>
                      <ol>
                        {section.articles.map((article) => (
                          <li>
                            <a href={`/article/${article.slug}/`}>{article.title}</a>
                            <p>{article.subtitle}</p>
                          </li>
                        ))}
                      </ol>
                    </section>
                  ))}
                </div>
              </section>
            )}
          </div>
        )}
      </>
    ) : (
      <div class="empty-front-page">
        <h2>No published articles yet.</h2>
        <p>Add Markdown files to <code>content/articles/published</code> or run the Worker in dry-run mode.</p>
      </div>
    )}
  </section>
</BaseLayout>
