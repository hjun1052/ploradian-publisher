---
import Ploradian2013Layout from "../../../../layouts/Ploradian2013Layout.astro";
import { formatDisplayDate, getPublishedArticles } from "../../../../lib/articles";

export async function getStaticPaths() {
  const articles = await getPublishedArticles();
  return articles.map((article) => {
    const relatedArticles = articles
      .filter((candidate) => candidate.slug !== article.slug && candidate.category === article.category)
      .slice(0, 2);
    const relatedSlugs = new Set(relatedArticles.map((candidate) => candidate.slug));
    const latestArticles = articles
      .filter((candidate) => candidate.slug !== article.slug && !relatedSlugs.has(candidate.slug))
      .slice(0, 3);

    return {
      params: { slug: article.slug },
      props: { article, relatedArticles, latestArticles }
    };
  });
}

const { article, relatedArticles, latestArticles } = Astro.props;
const canonicalPath = `/article/${article.slug}/`;
const publishedIso = new Date(article.date).toISOString();
const imageAlt = article.image_alt || article.title;
const heroImageStyle = article.image_url ? `--p13-hero-image: url("${article.image_url}")` : undefined;
const unsplashCreditUrl = "https://unsplash.com/?utm_source=the_ploradian&utm_medium=referral";
---

<Ploradian2013Layout
  title={article.title}
  description={article.excerpt}
  canonicalPath={canonicalPath}
  alternatePath={canonicalPath}
  ogType="article"
  publishedTime={publishedIso}
  modifiedTime={publishedIso}
  articleSection={article.category}
  imagePath={article.image_url}
  imageAlt={imageAlt}
>
  <article class="p13-article-shell">
    <header class="p13-article-hero" style={heroImageStyle}>
      <div class="p13-article-hero-content">
        <p class="p13-kicker">{article.category}</p>
        <h1><span class="p13-title-strip">{article.title}</span></h1>
        <p><span class="p13-subtitle-strip">{article.subtitle}</span></p>
        <p class="p13-article-meta">
          <time datetime={article.date}>{formatDisplayDate(article.date)}</time>
          <span>/</span>
          <span>{article.readingMinutes} min read</span>
          <span>/</span>
          <span>{article.generated_by}</span>
        </p>
      </div>
    </header>

    {article.image_url && (
      <figure class="p13-featured-image">
        <img src={article.image_url} alt={imageAlt} decoding="async" />
        {article.image_credit_name && article.image_credit_url && (
          <figcaption>
            Photo by
            {" "}
            <a href={article.image_credit_url} rel="noopener noreferrer" target="_blank">
              {article.image_credit_name}
            </a>
            {" "}
            on
            {" "}
            <a href={unsplashCreditUrl} rel="noopener noreferrer" target="_blank">Unsplash</a>
          </figcaption>
        )}
      </figure>
    )}

    <div class="p13-prose" set:html={article.html} />

    <section class="p13-reactions" data-reactions data-reaction-slug={article.slug} aria-labelledby="p13-reactions-title">
      <h2 id="p13-reactions-title">공감</h2>
      <button class="p13-heart-button" type="button" data-reaction-kind="heart" aria-label="이 기사에 하트 보내기">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M12 20.7l-.86-.78C4.74 14.12 2 11.48 2 7.76 2 4.72 4.38 2.4 7.42 2.4c1.72 0 3.37.8 4.08 2.05A4.95 4.95 0 0 1 15.58 2.4C18.62 2.4 21 4.72 21 7.76c0 3.72-2.74 6.36-9.14 12.16l-.86.78Z" />
        </svg>
        <span>하트</span>
        <strong data-reaction-count="heart">0</strong>
      </button>
      <p data-reaction-status aria-live="polite"></p>
    </section>

    <footer class="p13-source-box">
      <p>정보 출처: {article.source_name} 기사에서 정보를 파밍함.</p>
      <p>
        원문:
        <a href={article.source_url} rel="noopener noreferrer" target="_blank">{article.original_title}</a>
      </p>
      <p>본 기사는 실제 보도를 바탕으로 재구성한 풍자 콘텐츠입니다.</p>
    </footer>

    {(relatedArticles.length > 0 || latestArticles.length > 0) && (
      <aside class="p13-followups" aria-label="More stories">
        {relatedArticles.length > 0 && (
          <section>
            <h2>RELATED</h2>
            <ol class="p13-followup-list">
              {relatedArticles.map((item) => (
                <li>
                  <a href={`/2013/article/${item.slug}/`}>{item.title}</a>
                  <p class="p13-meta">
                    <span>{item.category}</span>
                    <time datetime={item.date}>{formatDisplayDate(item.date)}</time>
                  </p>
                </li>
              ))}
            </ol>
          </section>
        )}

        {latestArticles.length > 0 && (
          <section>
            <h2>LATEST</h2>
            <ol class="p13-followup-list">
              {latestArticles.map((item) => (
                <li>
                  <a href={`/2013/article/${item.slug}/`}>{item.title}</a>
                  <p class="p13-meta">
                    <span>{item.category}</span>
                    <time datetime={item.date}>{formatDisplayDate(item.date)}</time>
                  </p>
                </li>
              ))}
            </ol>
          </section>
        )}
      </aside>
    )}
  </article>

  <script>
    const reactionBlocks = document.querySelectorAll("[data-reactions]");
    const reactionLabels = { heart: "하트" };

    function todayKey() {
      return new Date().toISOString().slice(0, 10);
    }

    function setCounts(block, counts) {
      const count = Number(counts?.heart || 0);
      const countElement = block.querySelector('[data-reaction-count="heart"]');
      if (countElement) countElement.textContent = new Intl.NumberFormat("ko-KR").format(count);
    }

    function markLocalReaction(block, slug) {
      const key = `ploradian:reaction:${todayKey()}:${slug}:heart`;
      if (window.localStorage.getItem(key)) {
        block.querySelector('[data-reaction-kind="heart"]')?.setAttribute("aria-pressed", "true");
      }
    }

    async function loadReactionCounts(block, slug) {
      if (block.dataset.reactionsLoaded === "true") return;
      block.dataset.reactionsLoaded = "true";

      try {
        const response = await fetch(`/api/reactions?slug=${encodeURIComponent(slug)}`, {
          headers: { accept: "application/json" }
        });
        if (response.ok) {
          const data = await response.json();
          setCounts(block, data.counts);
        }
      } catch {
        block.setAttribute("data-reactions-offline", "true");
      }
    }

    reactionBlocks.forEach((block) => {
      const slug = block.dataset.reactionSlug;
      const status = block.querySelector("[data-reaction-status]");
      if (!slug) return;

      markLocalReaction(block, slug);

      if ("IntersectionObserver" in window) {
        const observer = new IntersectionObserver((entries) => {
          if (!entries.some((entry) => entry.isIntersecting)) return;

          observer.disconnect();
          void loadReactionCounts(block, slug);
        }, { rootMargin: "360px 0px" });
        observer.observe(block);
      } else {
        void loadReactionCounts(block, slug);
      }

      block.addEventListener("click", async (event) => {
        const button = event.target instanceof Element ? event.target.closest("[data-reaction-kind]") : null;
        if (!(button instanceof HTMLButtonElement)) return;

        button.disabled = true;
        if (status) status.textContent = "";
        await loadReactionCounts(block, slug);

        try {
          const response = await fetch("/api/reactions", {
            method: "POST",
            headers: {
              accept: "application/json",
              "content-type": "application/json"
            },
            body: JSON.stringify({ slug, reaction: "heart" })
          });
          const data = await response.json();
          if (!response.ok || !data.ok) throw new Error(data.error || "reaction failed");

          setCounts(block, data.counts);
          button.setAttribute("aria-pressed", "true");
          window.localStorage.setItem(`ploradian:reaction:${todayKey()}:${slug}:heart`, "1");
          if (status) status.textContent = data.duplicate ? "오늘 이미 접수됨" : `${reactionLabels.heart} 접수됨`;
        } catch {
          if (status) status.textContent = "반응 접수 실패";
        } finally {
          button.disabled = false;
        }
      });
    });
  </script>
</Ploradian2013Layout>
