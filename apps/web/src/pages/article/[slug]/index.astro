---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { formatDisplayDate, getArticleBySlug, getPublishedArticles } from "../../../lib/articles";

export async function getStaticPaths() {
  const articles = await getPublishedArticles();
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article }
  }));
}

const { article } = Astro.props;
const canonicalPath = `/article/${article.slug}/`;
const canonicalUrl = new URL(canonicalPath, Astro.site ?? "https://news.ploradian.com").toString();
const publishedIso = new Date(article.date).toISOString();
const articleStructuredData = [
  {
    "@type": "SatiricalArticle",
    "@id": `${canonicalUrl}#article`,
    headline: article.title,
    description: article.subtitle,
    articleSection: article.category,
    datePublished: publishedIso,
    dateModified: publishedIso,
    inLanguage: "ko-KR",
    isAccessibleForFree: true,
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": canonicalUrl
    },
    author: {
      "@type": "Organization",
      name: "The Ploradian Automated Desk"
    },
    publisher: {
      "@id": new URL("/#organization", Astro.site ?? "https://news.ploradian.com").toString()
    },
    citation: article.source_url,
    isBasedOn: {
      "@type": "CreativeWork",
      name: article.original_title,
      url: article.source_url,
      publisher: {
        "@type": "Organization",
        name: article.source_name
      }
    }
  },
  {
    "@type": "BreadcrumbList",
    "@id": `${canonicalUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Latest",
        item: new URL("/", Astro.site ?? "https://news.ploradian.com").toString()
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Archive",
        item: new URL("/archive/", Astro.site ?? "https://news.ploradian.com").toString()
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.title,
        item: canonicalUrl
      }
    ]
  }
];
---

<BaseLayout
  title={article.title}
  description={article.excerpt}
  canonicalPath={canonicalPath}
  ogType="article"
  publishedTime={publishedIso}
  modifiedTime={publishedIso}
  articleSection={article.category}
  structuredData={articleStructuredData}
>
  <article class="site-shell article-detail">
    <header class="article-hero">
      <p class="kicker">{article.category}</p>
      <h1>{article.title}</h1>
      <p class="article-subtitle">{article.subtitle}</p>
      <p class="article-meta">
        <time datetime={article.date}>{formatDisplayDate(article.date)}</time>
        <span aria-hidden="true">/</span>
        <span>{article.readingMinutes} min read</span>
        <span aria-hidden="true">/</span>
        <span>Generated by {article.generated_by}</span>
      </p>
    </header>

    <div class="article-prose" set:html={article.html} />

    <footer class="source-box">
      <p>정보 출처: {article.source_name} 기사에서 정보를 파밍함.</p>
      <p>
        원문:
        <a href={article.source_url} rel="noopener noreferrer" target="_blank">{article.original_title}</a>
      </p>
      <p>본 기사는 실제 보도를 바탕으로 재구성한 풍자 콘텐츠입니다.</p>
    </footer>
  </article>
</BaseLayout>
