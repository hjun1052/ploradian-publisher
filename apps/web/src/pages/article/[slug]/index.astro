---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { formatDisplayDate, getPublishedArticles } from "../../../lib/articles";

export async function getStaticPaths() {
  const articles = await getPublishedArticles();
  return articles.map((article) => {
    const relatedArticles = articles
      .filter((candidate) => candidate.slug !== article.slug && candidate.category === article.category)
      .slice(0, 2);
    const relatedSlugs = new Set(relatedArticles.map((candidate) => candidate.slug));
    const latestArticles = articles
      .filter((candidate) => candidate.slug !== article.slug && !relatedSlugs.has(candidate.slug))
      .slice(0, 3);

    return {
      params: { slug: article.slug },
      props: { article, relatedArticles, latestArticles }
    };
  });
}

const { article, relatedArticles, latestArticles } = Astro.props;
const canonicalPath = `/article/${article.slug}/`;
const canonicalUrl = new URL(canonicalPath, Astro.site ?? "https://news.ploradian.com").toString();
const publishedIso = new Date(article.date).toISOString();
const imageAlt = article.image_alt || article.title;
const unsplashCreditUrl = "https://unsplash.com/?utm_source=the_ploradian&utm_medium=referral";
const articleStructuredData = [
  {
    "@type": "SatiricalArticle",
    "@id": `${canonicalUrl}#article`,
    headline: article.title,
    description: article.subtitle,
    articleSection: article.category,
    datePublished: publishedIso,
    dateModified: publishedIso,
    inLanguage: "ko-KR",
    isAccessibleForFree: true,
    ...(article.image_url ? { image: [article.image_url] } : {}),
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": canonicalUrl
    },
    author: {
      "@type": "Organization",
      name: "The Ploradian Automated Desk"
    },
    publisher: {
      "@id": new URL("/#organization", Astro.site ?? "https://news.ploradian.com").toString()
    },
    citation: article.source_url,
    isBasedOn: {
      "@type": "CreativeWork",
      name: article.original_title,
      url: article.source_url,
      publisher: {
        "@type": "Organization",
        name: article.source_name
      }
    }
  },
  {
    "@type": "BreadcrumbList",
    "@id": `${canonicalUrl}#breadcrumb`,
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Latest",
        item: new URL("/", Astro.site ?? "https://news.ploradian.com").toString()
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Archive",
        item: new URL("/archive/", Astro.site ?? "https://news.ploradian.com").toString()
      },
      {
        "@type": "ListItem",
        position: 3,
        name: article.title,
        item: canonicalUrl
      }
    ]
  }
];
---

<BaseLayout
  title={article.title}
  description={article.excerpt}
  canonicalPath={canonicalPath}
  ogType="article"
  publishedTime={publishedIso}
  modifiedTime={publishedIso}
  articleSection={article.category}
  imagePath={article.image_url}
  imageAlt={imageAlt}
  structuredData={articleStructuredData}
>
  <article class="site-shell article-detail">
    <header class="article-hero">
      <p class="kicker">{article.category}</p>
      <h1>{article.title}</h1>
      <p class="article-subtitle">{article.subtitle}</p>
      <p class="article-meta">
        <time datetime={article.date}>{formatDisplayDate(article.date)}</time>
        <span aria-hidden="true">/</span>
        <span>{article.readingMinutes} min read</span>
        <span aria-hidden="true">/</span>
        <span>Generated by {article.generated_by}</span>
        <span aria-hidden="true">/</span>
        <button class="copy-link-button" type="button" data-copy-link data-copy-url={canonicalUrl}>Copy link</button>
        <span class="copy-link-status" data-copy-status aria-live="polite"></span>
      </p>
    </header>

    {article.image_url && (
      <figure class="article-featured-image">
        <img src={article.image_url} alt={imageAlt} decoding="async" />
        {article.image_credit_name && article.image_credit_url && (
          <figcaption>
            Photo by
            {" "}
            <a href={article.image_credit_url} rel="noopener noreferrer" target="_blank">
              {article.image_credit_name}
            </a>
            {" "}
            on
            {" "}
            <a href={unsplashCreditUrl} rel="noopener noreferrer" target="_blank">Unsplash</a>
          </figcaption>
        )}
      </figure>
    )}

    <div class="article-prose" set:html={article.html} />

    <footer class="source-box">
      <p>정보 출처: {article.source_name} 기사에서 정보를 파밍함.</p>
      <p>
        원문:
        <a href={article.source_url} rel="noopener noreferrer" target="_blank">{article.original_title}</a>
      </p>
      <p>본 기사는 실제 보도를 바탕으로 재구성한 풍자 콘텐츠입니다.</p>
    </footer>

    {(relatedArticles.length > 0 || latestArticles.length > 0) && (
      <aside class="article-followups" aria-label="More stories">
        {relatedArticles.length > 0 && (
          <section>
            <h2>Related</h2>
            <ol class="article-followup-list">
              {relatedArticles.map((item) => (
                <li>
                  <a href={`/article/${item.slug}/`}>{item.title}</a>
                  <p>
                    <span>{item.category}</span>
                    <span aria-hidden="true">/</span>
                    <time datetime={item.date}>{formatDisplayDate(item.date)}</time>
                  </p>
                </li>
              ))}
            </ol>
          </section>
        )}

        {latestArticles.length > 0 && (
          <section>
            <h2>Latest</h2>
            <ol class="article-followup-list">
              {latestArticles.map((item) => (
                <li>
                  <a href={`/article/${item.slug}/`}>{item.title}</a>
                  <p>
                    <span>{item.category}</span>
                    <span aria-hidden="true">/</span>
                    <time datetime={item.date}>{formatDisplayDate(item.date)}</time>
                  </p>
                </li>
              ))}
            </ol>
          </section>
        )}
      </aside>
    )}
  </article>

  <script>
    const buttons = document.querySelectorAll("[data-copy-link]");

    async function copyText(text) {
      if (navigator.clipboard?.writeText) {
        try {
          await navigator.clipboard.writeText(text);
          return;
        } catch {
          // Fall through to the legacy copy path when browser permissions block Clipboard API.
        }
      }

      const textarea = document.createElement("textarea");
      textarea.value = text;
      textarea.setAttribute("readonly", "");
      textarea.style.position = "fixed";
      textarea.style.top = "-1000px";
      document.body.appendChild(textarea);
      textarea.focus();
      textarea.select();
      textarea.setSelectionRange(0, textarea.value.length);
      const copied = document.execCommand("copy");
      textarea.remove();
      if (!copied) {
        throw new Error("copy command failed");
      }
    }

    buttons.forEach((button) => {
      button.addEventListener("click", async () => {
        if (!(button instanceof HTMLButtonElement)) return;

        const url = button.dataset.copyUrl || window.location.href;
        const original = button.textContent || "Copy link";
        const status = button.parentElement?.querySelector("[data-copy-status]");
        try {
          await copyText(url);
          button.textContent = "Copied";
          if (status) status.textContent = "";
          window.setTimeout(() => {
            button.textContent = original;
          }, 1800);
        } catch {
          const manual = document.createElement("input");
          manual.className = "copy-link-manual";
          manual.value = url;
          manual.setAttribute("readonly", "");
          button.after(manual);
          manual.focus();
          manual.select();
          button.textContent = "Copy manually";
          if (status) status.textContent = "Press Cmd+C";
          window.setTimeout(() => {
            manual.remove();
            button.textContent = original;
            if (status) status.textContent = "";
          }, 3600);
        }
      });
    });
  </script>
</BaseLayout>
