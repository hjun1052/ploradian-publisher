---
import { formatDisplayDate, getPublishedArticles } from "../../../../lib/articles";

export async function getStaticPaths() {
  const articles = await getPublishedArticles();
  return articles.map((article, index) => ({
    params: { slug: article.slug },
    props: {
      article,
      previousArticle: articles[index + 1] ?? null,
      nextArticle: articles[index - 1] ?? null
    }
  }));
}

const { article, previousArticle, nextArticle } = Astro.props;
const siteUrl = Astro.site ?? new URL("https://news.ploradian.com");
const canonicalPath = `/article/${article.slug}/`;
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const classicUrl = new URL(`/classic/article/${article.slug}/`, siteUrl).toString();
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index, follow" />
    <meta name="description" content={article.excerpt} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="text/html" title="Classic Edition" href={classicUrl} />
    <link rel="alternate" type="application/rss+xml" title="The Ploradian RSS" href="/feed.xml" />
    <title>{article.title} - The Ploradian Classic</title>
    <style is:global>
      body { max-width: 720px; margin: 24px auto; padding: 0 12px; line-height: 1.65; }
      img { max-width: 100%; height: auto; }
      blockquote { border-left: 3px solid #999; margin-left: 0; padding-left: 12px; }
      pre { overflow: auto; }
    </style>
  </head>
  <body>
    <p>
      <a href="/classic/">Classic Home</a>
      |
      <a href={canonicalPath}>Modern Article</a>
      |
      <a href="/feed.xml">RSS</a>
      |
      <a href="/llms-full.txt">Full Text</a>
    </p>
    <hr />

    <article>
      <p><strong>{article.category}</strong></p>
      <h1>{article.title}</h1>
      <p><strong>{article.subtitle}</strong></p>
      <p>
        <time datetime={article.date}>{formatDisplayDate(article.date)}</time>
        /
        {article.readingMinutes} min read
        /
        Generated by {article.generated_by}
      </p>

      {article.image_url && (
        <p>
          Image:
          <a href={article.image_url}>{article.image_alt || article.title}</a>
        </p>
      )}

      <hr />
      <div set:html={article.html} />
      <hr />

      <h2>Source</h2>
      <p>
        Original:
        <a href={article.source_url}>{article.original_title}</a>
        ({article.source_name})
      </p>
      <p>본 기사는 실제 보도를 바탕으로 재구성한 풍자 콘텐츠입니다.</p>
    </article>

    <hr />
    <p>
      {previousArticle && (
        <>
          Older:
          {" "}
          <a href={`/classic/article/${previousArticle.slug}/`}>{previousArticle.title}</a>
          <br />
        </>
      )}
      {nextArticle && (
        <>
          Newer:
          {" "}
          <a href={`/classic/article/${nextArticle.slug}/`}>{nextArticle.title}</a>
        </>
      )}
    </p>
  </body>
</html>
