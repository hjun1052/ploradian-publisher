---
import "@fontsource/newsreader/400.css";
import "@fontsource/newsreader/500.css";
import "@fontsource/newsreader/600.css";
import "@fontsource/newsreader/700.css";
import "@fontsource/noto-serif-kr/korean-400.css";
import "@fontsource/noto-serif-kr/korean-500.css";
import "@fontsource/noto-serif-kr/korean-700.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/700.css";
import "@fontsource/noto-sans-kr/korean-400.css";
import "@fontsource/noto-sans-kr/korean-500.css";
import "@fontsource/noto-sans-kr/korean-700.css";
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  imagePath?: string;
  imageAlt?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  articleSection?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  showHeader?: boolean;
}

const {
  title = "The Ploradian",
  description = "The Ploradian은 기술, 비즈니스, 시장, 헛소리 뉴스를 한국어 풍자 기사로 자동 발행하는 온라인 신문입니다.",
  canonicalPath,
  imagePath = "/ploradian-mark.svg",
  imageAlt = "The Ploradian masthead mark",
  ogType = "website",
  publishedTime,
  modifiedTime,
  articleSection,
  structuredData,
  showHeader = true
} = Astro.props;

const pageTitle = title === "The Ploradian" ? title : `${title} - The Ploradian`;
const siteUrl = Astro.site ?? new URL("https://news.ploradian.com");
const canonicalUrl = new URL(canonicalPath ?? Astro.url.pathname, siteUrl).toString();
const imageUrl = new URL(imagePath, siteUrl).toString();
const siteName = "The Ploradian";
const organizationId = new URL("/#organization", siteUrl).toString();
const websiteId = new URL("/#website", siteUrl).toString();
const baseStructuredData: Array<Record<string, unknown>> = [
  {
    "@type": "Organization",
    "@id": organizationId,
    name: siteName,
    url: new URL("/", siteUrl).toString(),
    logo: {
      "@type": "ImageObject",
      url: new URL("/ploradian-mark.svg", siteUrl).toString()
    }
  },
  {
    "@type": "WebSite",
    "@id": websiteId,
    name: siteName,
    url: new URL("/", siteUrl).toString(),
    inLanguage: "ko-KR",
    publisher: {
      "@id": organizationId
    },
    potentialAction: {
      "@type": "SearchAction",
      target: `${new URL("/archive/", siteUrl).toString()}?q={search_term_string}`,
      "query-input": "required name=search_term_string"
    }
  }
];
const pageStructuredData = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [...baseStructuredData, ...pageStructuredData]
}).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#f8f5ed" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="ko-KR" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:locale" content="ko_KR" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {articleSection && <meta property="article:section" content={articleSection} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <link rel="icon" href="/ploradian-mark.svg" />
    <link rel="alternate" type="application/rss+xml" title="The Ploradian RSS" href="/feed.xml" />
    <link rel="alternate" type="text/plain" title="The Ploradian LLM index" href="/llms.txt" />
    <link rel="alternate" type="text/plain" title="The Ploradian full-text LLM corpus" href="/llms-full.txt" />
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />
    <script type="application/ld+json" set:html={jsonLd} />
    <title>{pageTitle}</title>
  </head>
  <body>
    {showHeader && <SiteHeader />}
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-shell footer-grid">
        <p>The Ploradian publishes satirical technology and business coverage from automated Markdown workflows.</p>
        <p>본 사이트의 기사는 실제 보도를 바탕으로 재구성한 풍자 콘텐츠입니다.</p>
        <p><a href="/feed.xml">RSS</a> · <a href="/sitemap.xml">Sitemap</a> · <a href="/llms.txt">LLMs</a></p>
      </div>
    </footer>
  </body>
</html>
