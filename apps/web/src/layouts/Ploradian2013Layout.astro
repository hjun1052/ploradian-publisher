---
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/700.css";
import "@fontsource/noto-sans-kr/korean-400.css";
import "@fontsource/noto-sans-kr/korean-500.css";
import "@fontsource/noto-sans-kr/korean-700.css";
import "../styles/ploradian2013.css";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  imagePath?: string;
  imageAlt?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  articleSection?: string;
  alternatePath?: string;
}

const {
  title = "The Ploradian 2013",
  description = "The Ploradian 2013은 2013년 모바일 앱 웹 감성으로 다시 읽는 플로라디안 기사판입니다.",
  canonicalPath,
  imagePath = "/ploradian-mark.svg",
  imageAlt = "The Ploradian mark",
  ogType = "website",
  publishedTime,
  modifiedTime,
  articleSection,
  alternatePath
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://news.ploradian.com");
const canonicalUrl = new URL(canonicalPath ?? Astro.url.pathname, siteUrl).toString();
const currentUrl = new URL(Astro.url.pathname, siteUrl).toString();
const imageUrl = new URL(imagePath, siteUrl).toString();
const pageTitle = title === "The Ploradian 2013" ? title : `${title} - The Ploradian 2013`;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#eeeeeb" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="ko-KR" href={currentUrl} />
    {alternatePath && <link rel="alternate" type="text/html" title="Modern Edition" href={new URL(alternatePath, siteUrl).toString()} />}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="The Ploradian" />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:locale" content="ko_KR" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {articleSection && <meta property="article:section" content={articleSection} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <link rel="icon" href="/ploradian-mark.svg" />
    <link rel="alternate" type="application/rss+xml" title="The Ploradian RSS" href="/feed.xml" />
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />
    <title>{pageTitle}</title>
  </head>
  <body class="p13-body">
    <div class="p13-page">
      <header class="p13-topbar">
        <a class="p13-menu" href="/2013/" aria-label="The Ploradian 2013 home">
          <span></span>
          <span></span>
          <span></span>
        </a>
        <form class="p13-search" action="/archive/" method="get">
          <input name="q" type="search" placeholder="기사 검색" aria-label="기사 검색" />
          <button type="submit" aria-label="검색">⌕</button>
        </form>
        <nav class="p13-nav" aria-label="2013 edition navigation">
          <a href="/">MODERN</a>
          <a href="/archive/">ARCHIVE</a>
          <a href="/classic/">CLASSIC</a>
          <a href="/feed.xml">RSS</a>
        </nav>
        <a class="p13-wordmark" href="/2013/">THE PLORADIAN 2013</a>
      </header>
      <main>
        <slot />
      </main>
      <footer class="p13-footer">
        <p>THE PLORADIAN 2013 / app-era skin for irresponsible seriousness.</p>
        <p><a href="/">Modern</a> · <a href="/classic/">Classic</a> · <a href="/llms-full.txt">Full Text</a></p>
      </footer>
    </div>
  </body>
</html>
